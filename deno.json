{
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "@std/cli": "jsr:@std/cli@^1.0.28",
    "@std/path": "jsr:@std/path@^1",
    "@std/toml": "jsr:@std/toml@^1",
    "@std/fs": "jsr:@std/fs@^1",
    "esbuild": "npm:esbuild@^0.25.5"
  },
  "nodeModulesDir": "auto",
  "tasks": {
    "build": "deno run -A cli/claudecode-plugin/scripts/build.ts",
    "dev": "deno run --allow-all cli/main.ts",
    "install-plugin": "deno run -A --config deno.json cli/claudecode-plugin/scripts/installer.ts install",
    "test": "deno test --allow-all",
    "install": "deno task install-plugin",
    "uninstall-plugin": "deno run -A --config deno.json cli/claudecode-plugin/scripts/installer.ts uninstall",
    "uninstall": "deno task uninstall-plugin"
  },
  "compilerOptions": {
    "lib": ["deno.window"]
  }
}
